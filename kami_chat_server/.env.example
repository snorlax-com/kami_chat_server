PORT=3000
RESEND_API_KEY=
# 主通知先（いずれか必須）。未設定時はもう一方を使用。
ADMIN_EMAIL=your@gmail.com
# 任意。設定時は ADMIN_EMAIL より優先して主宛先に使う（通常・至急の両方のベース）。
# DEV_NOTIFICATION_EMAIL=your@gmail.com
#
# 至急（priority_guidance）時のみ、主宛先に加えて送る追加通知先。
# 未設定時は emergencyauraface@gmail.com（コード内デフォルト）。
# EMERGENCY_NOTIFICATION_EMAIL=emergencyauraface@gmail.com
#
# 未設定時は主宛先ロジック（DEV → ADMIN）にフォールバック。種別ごとに別 inbox にしたい場合のみ設定。
# MAIL_TO_PRIORITY=urgent-inbox@gmail.com
# MAIL_TO_NORMAL=normal-inbox@gmail.com
MAIL_FROM=AuraFace <onboarding@resend.dev>
BASE_URL=http://127.0.0.1:3000
TOKEN_SECRET=change-me-in-development-only

# 任意。至急（priority_guidance）を JST の時刻帯に限定する場合のみ、次の両方を 0–23 の整数で設定。
# 未設定（または片方だけ）のときは 24 時間受付（Flutter アプリのデフォルトと一致）。
# CONSULTATION_URGENT_JST_HOUR_START=10
# CONSULTATION_URGENT_JST_HOUR_END=23

# --- ゲスト診断・認証連携（SQLite + Firebase ID トークン検証）---
# サービスアカウント JSON を1行の文字列で（Render の multiline 不可のときは base64 化してデコードする改造も可）
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# SQLite ファイルのディレクトリ（既定: kami_chat_server/data）。Render のエフェメラル FS のため再起動で消える点に注意。
# IDENTITY_DB_DIR=./data
#
# ローカル開発のみ: claim / GET /me をトークンなしで試すとき（本番では無効）
# IDENTITY_DEV_SECRET=dev-only-secret
# IDENTITY_DEV_UID=test-firebase-uid-123
