{
  "name": "kami-chat-server",
  "version": "1.0.0",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test:send-receive-send": "node scripts/send-receive-send-test.js",
    "test:send-receive-send:prod": "node scripts/send-receive-send-test.js https://kami-chat-server.onrender.com",
    "test:e2e": "node scripts/e2e-full-flow-test.js",
    "test:render-smoke": "node scripts/render-production-smoke.js https://kami-chat-server.onrender.com",
    "test:local-all": "bash scripts/run-local-e2e.sh",
    "test:consultation-mail": "node --test test/*.test.js",
    "test:identity-api": "node scripts/identity-api-e2e.js",
    "test:all": "node --test test/*.test.js && node scripts/identity-api-e2e.js",
    "firebase:b64": "node scripts/firebase-service-account-to-b64.js",
    "render:upsert-firebase-b64": "node scripts/render-upsert-env-from-file.js FIREBASE_SERVICE_ACCOUNT_JSON_B64 ./secrets/render-FIREBASE_SERVICE_ACCOUNT_JSON_B64.txt"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.6.0",
    "resend": "^4.0.1"
  }
}
